# Потрібно ЛИШЕ для роботи на Vercel із Supabase.
# Локальний запуск (node serve.js / npm start) використовує SQLite і цих ключів НЕ потребує.
#
# Де взяти: Supabase Dashboard → Project Settings → API
#   Project URL        -> SUPABASE_URL
#   service_role key    -> SUPABASE_SERVICE_ROLE_KEY  (СЕКРЕТНИЙ, лише на сервері!)
#
# На Vercel ці значення додають у: Project → Settings → Environment Variables
# (НЕ коміть реальні ключі у репозиторій).

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
